# FreelanceFlow Client API Manual Test Suite
# Requires VS Code REST Client extension or similar

@baseUrl = http://localhost:5000/api/v1
@contentType = application/json

### 1. Register a new freelancer (To get token)
# @name register
POST {{baseUrl}}/auth/register
Content-Type: {{contentType}}

{
  "name": "Jane Doe",
  "email": "jane.doe@example.com",
  "password": "password123",
  "businessName": "JD Freelancing"
}

###

### 2. Login (To get token)
# @name login
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "email": "jane.doe@example.com",
  "password": "password123"
}

###

# Copy the token value from the register/login response above and paste here
@authToken = {{login.response.body.data.token}}

### 3. Create a client (T-018)
# @name createClient
POST {{baseUrl}}/clients
Content-Type: {{contentType}}
Authorization: Bearer {{authToken}}

{
  "name": "Acme Corporation",
  "email": "billing@acme.org",
  "phone": "+91-9876543210",
  "company": "Acme Inc.",
  "address": "456 Main St, Mumbai",
  "notes": "Prefers invoices on the 1st of the month"
}

###

@clientId = {{createClient.response.body.data._id}}

### 4. Attempt to create a client with duplicate email (T-015 uniqueness)
POST {{baseUrl}}/clients
Content-Type: {{contentType}}
Authorization: Bearer {{authToken}}

{
  "name": "Acme Duplicate",
  "email": "billing@acme.org"
}

###

### 5. Get clients list with pagination & filters (T-017)
GET {{baseUrl}}/clients?page=1&limit=5&sort=name&order=asc&isArchived=false
Authorization: Bearer {{authToken}}

###

### 6. Get single client details (T-018)
GET {{baseUrl}}/clients/{{clientId}}
Authorization: Bearer {{authToken}}

###

### 7. Update client details (T-018)
PUT {{baseUrl}}/clients/{{clientId}}
Content-Type: {{contentType}}
Authorization: Bearer {{authToken}}

{
  "notes": "Prefers invoices on the 1st of the month - Updated notes",
  "phone": "+91-9988776655"
}

###

### 8. Archive client (T-017 / T-018 soft delete)
DELETE {{baseUrl}}/clients/{{clientId}}
Authorization: Bearer {{authToken}}

###
