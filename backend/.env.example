# Server Config
PORT=5000
NODE_ENV=development

# Database Config
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/freelanceflow?retryWrites=true&w=majority

# Security Config
JWT_SECRET=your_super_secret_jwt_sign_key_here
JWT_EXPIRES_IN=7d

# Email Config (SMTP)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
CRON_TIMEZONE=Asia/Kolkata
